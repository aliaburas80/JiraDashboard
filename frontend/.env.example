# ─────────────────────────────────────────────────────────────
# Delivery Clarity — Frontend environment variables
# Copy to frontend/.env before running the React app.
# All variables MUST be prefixed with REACT_APP_ to be
# accessible inside the browser bundle.
# ─────────────────────────────────────────────────────────────

# Full base URL of the backend API (no trailing slash)
REACT_APP_API_BASE=http://localhost:4000/api
