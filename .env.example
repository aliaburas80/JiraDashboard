# ─────────────────────────────────────────────────────────────
# Delivery Clarity — Environment Variables
# Copy this file to .env and fill in your values.
# .env is already in .gitignore — never commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────

# Port the Node.js API server listens on.
PORT=4000

# Comma-separated list of allowed CORS origins (your frontend URL).
# In development you can leave this unset (allows all origins).
# In production set this to the exact URL of your frontend, e.g.:
#   ALLOWED_ORIGIN=https://delivery-clarity.example.com
ALLOWED_ORIGIN=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────

# Full base URL of the backend API.
# Must start with REACT_APP_ to be exposed to the React build.
REACT_APP_API_BASE=http://localhost:4000/api
