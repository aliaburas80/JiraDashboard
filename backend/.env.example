# ─────────────────────────────────────────────────────────────
# Delivery Clarity — Backend environment variables
# Copy to backend/.env before running the server.
# ─────────────────────────────────────────────────────────────

# Port the API server listens on (default: 4000)
PORT=4000

# Allowed CORS origin(s) — comma-separated for multiple.
# Leave unset to allow all origins (development only).
# Example production value:
#   ALLOWED_ORIGIN=https://delivery-clarity.example.com
ALLOWED_ORIGIN=http://localhost:3000
